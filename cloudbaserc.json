{
  "envId": "{{ENV_ID}}",
  "region": "ap-shanghai",
  "framework": {
    "name": "supervision-system",
    "plugins": {
      "function": {
        "use": "@cloudbase/framework-plugin-function"
      }
    }
  },
  "functionRoot": "./backend",
  "functions": [
    {
      "name": "supervision-system",
      "timeout": 30,
      "runtime": "Python3.tisan",
      "memorySize": 256,
      "envVariables": {
        "TZ": "Asia/Shanghai"
      },
      "installDependency": true,
      "handler": "index.main_handler",
      "triggers": [
        {
          "type": "http",
          "path": "/"
        }
      ]
    }
  ]
}
